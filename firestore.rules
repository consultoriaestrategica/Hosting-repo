rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // COLECCIÓN: staff
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // COLECCIÓN: family_members
    match /family_members/{familyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // COLECCIÓN: residents
    match /residents/{residentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // COLECCIÓN: dailyLogs
    match /dailyLogs/{logId} {
      allow read, write: if isAuthenticated();
    }

    // COLECCIÓN: logs (legacy)
    match /logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    // COLECCIÓN: resident_contracts
    match /resident_contracts/{contractId} {
      allow read, write: if isAuthenticated();
    }

    // COLECCIÓN: staff_contracts
    match /staff_contracts/{contractId} {
      allow read, write: if isAuthenticated();
    }

    // COLECCIÓN: settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // COLECCIÓN: users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // REGLA POR DEFECTO: DENEGAR TODO LO DEMÁS
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
