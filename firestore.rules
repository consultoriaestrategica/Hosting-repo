
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Esta regla permite que cualquier usuario autenticado lea y escriba en cualquier documento.
    // **ADVERTENCIA**: Esto es conveniente para el desarrollo, pero
    // **NO ES SEGURO** para producción. Deberías restringir el acceso
    // con reglas más granulares antes de lanzar tu aplicación.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
